{
  "manifest_version": 3,
  "name": "PageNoter",
  "version": "0.1.0",
  "description": "Save personal notes attached to specific web pages.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "PageNoter",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "activeTab", "tabs"],
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["theme.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}
